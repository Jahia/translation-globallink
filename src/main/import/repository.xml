<?xml version="1.0" encoding="UTF-8"?>
<content xmlns:j="http://www.jahia.org/jahia/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0">
    <modules jcr:primaryType="jnt:modules">
        <jahia-translation-globallink j:dependencies="bootstrap3-core default siteSettings"
                               j:modulePriority="0"
                               j:moduleType="module"
                               j:title="Global Link Translation"
                                    jcr:mixinTypes="jmix:hasExternalProviderExtension"
                               jcr:primaryType="jnt:module">
                <sources jcr:mixinTypes="jmix:hasExternalProviderExtension jmix:sourceControl"
                  jcr:primaryType="jnt:moduleVersionFolder"
                  j:staticMountPointProviderKey="module-jahia-translation-globallink-1.0-SNAPSHOT">
                    <src jcr:mixinTypes="jmix:sourceControl" jcr:primaryType="jnt:folder">
                        <main jcr:mixinTypes="jmix:sourceControl" jcr:primaryType="jnt:folder">
                            <resources jcr:primaryType="jnt:folder">
                                <META-INF jcr:primaryType="jnt:metaInfFolder">
                                    <definitions.cnd jcr:primaryType="jnt:definitionFile"/>
                                </META-INF>
                            </resources>
                        </main>
                    </src>
                </sources>
                
                <portlets jcr:primaryType="jnt:portletFolder"/>
                <files jcr:primaryType="jnt:folder">
                    <icon jcr:primaryType="jnt:folder">
                        <globalLink.png j:height="15"
                               j:width="16"
                               jcr:mixinTypes="jmix:image"
                               jcr:primaryType="jnt:file">
                            <jcr:content jcr:mimeType="image/png" jcr:primaryType="jnt:resource"/>
                            <thumbnail jcr:mimeType="image/png" jcr:primaryType="jnt:resource"/>
                            <thumbnail2 jcr:mimeType="image/png" jcr:primaryType="jnt:resource"/>
                        </globalLink.png>
                    </icon>
                </files>
                <contents jcr:primaryType="jnt:contentFolder"/>
                <templates j:rootTemplatePath="/base" jcr:primaryType="jnt:templatesFolder">
                    <files jcr:primaryType="jnt:folder"/>
                    <contents jcr:primaryType="jnt:contentFolder"/>
                    <site-settings-base j:hiddenTemplate="false"
                                j:view="siteSettings"
                                jcr:primaryType="jnt:template">
                        <j:translation_en jcr:language="en"
                                 jcr:mixinTypes="mix:title"
                                 jcr:primaryType="jnt:translation"
                                 jcr:title="site-settings-base"/>
                        <global-link-translation j:hiddenTemplate="false"
                                                   j:icon="/modules/jahia-translation-globallink/files/icon/globalLink.png"
                                                 j:view="siteSettings"
                                                   jcr:mixinTypes="jmix:useUILocale"
                                                   jcr:primaryType="jnt:template">
                        <j:translation_en jcr:language="en"
                                          jcr:mixinTypes="mix:title"
                                          jcr:primaryType="jnt:translation"
                                          jcr:title="Global Link Translation"/>
                        <globallink-translation-requests j:applyOn="jnt:virtualsite"
                                   j:defaultTemplate="false"
                                   j:hiddenTemplate="false"
                                                j:icon="/modules/jahia-translation-globallink/files/icon/globalLink.png"
                                    j:priority="100"
                                                j:view="siteSettings"
                                   jcr:primaryType="jnt:contentTemplate">
                            <j:translation_en jcr:language="en"
                                    jcr:mixinTypes="mix:title"
                                    jcr:primaryType="jnt:translation"
                                    jcr:title="GlobalLink Project Requests"/>
                            <pagecontent jcr:primaryType="jnt:contentList">
                                <globallink-requests jcr:primaryType="jnt:globalLinkRequestStatus">
                                    <j:translation_en jcr:language="en"
                                          jcr:mixinTypes="mix:title"
                                          jcr:primaryType="jnt:translation"
                                          jcr:title="GlobalLink Project Requests"/>
                                </globallink-requests>
                            </pagecontent>
                        </globallink-translation-requests>         
                        <globallink-translation-settings j:applyOn="jnt:virtualsite"
                                    j:icon="/modules/jahia-translation-globallink/files/icon/globalLink.png"
                                    j:defaultTemplate="false"
                                    j:hiddenTemplate="false"
                                    j:priority="100"
                                    jcr:primaryType="jnt:contentTemplate">
                            <j:translation_en jcr:language="en"
                                    jcr:mixinTypes="mix:title"
                                    jcr:primaryType="jnt:translation"
                                    jcr:title="GlobalLink Translation Settings"/>
                            <pagecontent jcr:primaryType="jnt:contentList">
                                <globallink-settings jcr:primaryType="jnt:globalLinkSettings">
                                    <j:translation_en jcr:language="en"
                                          jcr:mixinTypes="mix:title"
                                          jcr:primaryType="jnt:translation"
                                          jcr:title="GlobalLink Translation Settings"/>
                                </globallink-settings>
                            </pagecontent>
                        </globallink-translation-settings>
                        </global-link-translation>
                    </site-settings-base>
                </templates>
                
            </jahia-translation-globallink>
    </modules>
</content>
