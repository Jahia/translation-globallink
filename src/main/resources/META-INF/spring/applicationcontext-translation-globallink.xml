<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.2.xsd">
	
    <bean class="org.jahia.services.uicomponents.bean.toolbar.Item">
        <property name="actionItem">
            <bean class="org.jahia.ajax.gwt.client.widget.toolbar.action.NewContentActionItem">
		        <property name="nodeTypes" value="gblnt:globalLinkProject"/>
		        <property name="parentTypes" value="jnt:page"/>
	      	</bean>
        </property>
        <property name="title" value="GlobalLink Translation" />
        <property name="icon" value="/modules/jahia-translation-globallink/img/jnt_globalLinkProject.png"/>
        <property name="parent" value="editmode.tabs[0].treeContextMenu"/>
        <property name="positionBefore" value="Toolbar.Item.Publish"/>
    </bean>

	<bean id="globalLinkQueryService" class="org.jahia.translation.globallink.service.impl.GlobalLinkQueryServiceImpl" />
    
    <bean id="submissionService" class="org.jahia.translation.globallink.service.impl.GlobalLinkSubmissionServiceImpl">
    	<property name="gblQueryService" ref="globalLinkQueryService"/>
    	<property name="documentService" ref="documentService"/>
    	<property name="contentService" ref="contentService"/>
    </bean>
    
    <bean id="retrieveDocumentService" class="org.jahia.translation.globallink.service.impl.GlobalLinkRetrieveDocumentServiceImpl">
    	<property name="contentService" ref="contentService"/>
        <property name="queryService" ref="globalLinkQueryService"/>
    </bean>
    
    <bean id="translatedContentProcessService" class="org.jahia.translation.globallink.service.impl.GlobalLinkTranslatedContentProcessServiceImpl">
    	<property name="gblQueryService" ref="globalLinkQueryService"/>
    	<property name="documentService" ref="documentService"/>
    	<property name="contentService" ref="contentService"/>
    </bean>
    
    <bean id="documentService" class="org.jahia.translation.globallink.service.impl.GlobalLinkDocumentServiceImpl">
        <property name="contentService" ref="contentService"/>
    </bean>

    <bean id="contentService" class="org.jahia.translation.globallink.service.impl.SiteContentServiceImpl">
        <property name="queryService" ref="globalLinkQueryService"/>
    </bean>

    <bean class="org.jahia.translation.globallink.action.GlobalLinkConfigAction">
    </bean>
    <bean class="org.jahia.translation.globallink.action.GlobalLinkSubmissionCleanAction">
        <property name="jcrTemplate" ref="jcrTemplate"/>
    </bean>

    <bean parent="jobSchedulingBean">
        <property name="ramJob" value="true"/>
        <property name="jobDetail">
            <bean class="org.springframework.scheduling.quartz.JobDetailBean">
                <property name="name" value="translationJob" />
                <property name="jobClass" value="org.jahia.translation.globallink.job.GlobalLinkTranslationJob" />
            </bean>
        </property>
        <property name="trigger">
            <bean class="org.quartz.CronTrigger">
                <property name="name" value="TranslationJobTrigger"/>
                <property name="cronExpression" value="25 0/5 * * * ?"/>
            </bean>
        </property>
    </bean>

    <bean class="org.jahia.translation.globallink.choicelist.DisplayLocaleNameChoicelistInitializer"/>

    <bean class="org.jahia.services.uicomponents.bean.editmode.EngineConfiguration">
        <property name="key" value="gblnt:globalLinkProject"/>
        <property name="engineTabs">
            <list>
                <ref bean="Engine.Tab.Content"/>
            </list>
        </property>
        <property name="creationButtons">
            <list>
                <ref bean="Engine.Button.Create"/>
            </list>
        </property>
        <property name="editionButtons">
            <list>
                <ref bean="Engine.Button.Update"/>
            </list>
        </property>
        <property name="commonButtons">
            <list>
                <ref bean="Engine.Button.Cancel"/>
            </list>
        </property>
        <property name="parent" ref="editmode"/>
    </bean>


    <bean class="org.jahia.translation.globallink.rules.GlobalLinkSubmissionService" name="globalLinkSubmissionService">
        <property name="submissionService" ref="submissionService"/>
        <property name="queryService" ref="globalLinkQueryService"/>
        <property name="contentService" ref="contentService"/>
    </bean>

    <bean class="org.jahia.services.content.rules.ModuleGlobalObject">
        <property name="globalRulesObject">
            <map>
                <entry key="gblSubmissionService" value-ref="globalLinkSubmissionService"/>
            </map>
        </property>
    </bean>
</beans>