<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.2.xsd">

    <bean class="org.jahia.ajax.gwt.helper.ModuleGWTResources">
        <property name="CSSResources">
            <list>
                <value>/modules/jahia-translation-globallink/css/translation-globallink.css</value>
            </list>
        </property>
    </bean>

    <bean id="Toolbar.Item.translationGloballink" class="org.jahia.services.uicomponents.bean.toolbar.Item">
        <property name="actionItem">
            <bean class="org.jahia.ajax.gwt.client.widget.toolbar.action.NewContentActionItem">
                <property name="nodeTypes" value="gblnt:globalLinkProject"/>
                <property name="includeSubTypes" value="false"/>
                <property name="parentTypes" value="jnt:page"/>
            </bean>
        </property>
        <property name="requiredModule" value="jahia-translation-globallink"/>
        <property name="title" value="GlobalLink Translation" />
        <property name="icon" value="/modules/jahia-translation-globallink/img/module_GlobalLink.png"/>
        <property name="parent" value="editmode.tabs[0].treeContextMenu"/>
        <property name="positionBefore" value="Toolbar.Item.Publish"/>
    </bean>

    <bean class="org.jahia.services.uicomponents.bean.editmode.EngineConfiguration">
        <property name="key" value="gblnt:globalLinkProject"/>
        <property name="engineTabs">
            <list>
                <ref bean="Engine.Tab.Content"/>
            </list>
        </property>
        <property name="creationButtons">
            <list>
                <ref bean="Engine.Button.Create"/>
            </list>
        </property>
        <property name="editionButtons">
            <list>
                <ref bean="Engine.Button.Update"/>
            </list>
        </property>
        <property name="commonButtons">
            <list>
                <ref bean="Engine.Button.Cancel"/>
            </list>
        </property>
        <property name="parent" ref="editmode"/>
    </bean>
</beans>
